# Copy this file to ".env" and fill in your keys. Restart `npm start` after editing.
# Leave these blank to run in DEMO MODE (sample data, simulated payments).

# --- Supabase (backend) ---
# Get these from your Supabase project: Settings -> API
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# --- Currency / market ---
# Market: Saudi Arabia. SAR is the default; override here if ever needed.
EXPO_PUBLIC_CURRENCY=SAR
EXPO_PUBLIC_CURRENCY_SYMBOL="SAR "
